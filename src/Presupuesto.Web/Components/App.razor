<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Control de Gastos Personales</title>
    <meta name="description" content="Aplicación para el control de gastos mensuales personales" />
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="Presupuesto.Web.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    
    <!-- Custom Chart Script -->
    <script>
        let chartInstance = null;
        let hBarChartInstance = null;
        
        window.renderPieChart = (canvasId, labels, data, colors) => {
            const ctx = document.getElementById(canvasId);
            if (!ctx) return;
            
            if (chartInstance) {
                chartInstance.destroy();
            }
            
            chartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: colors,
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                font: {
                                    size: 12
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const value = context.raw;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = ((value / total) * 100).toFixed(1);
                                    return `${context.label}: $${value.toFixed(2)} (${percentage}%)`;
                                }
                            }
                        }
                    }
                }
            });
        };

        window.renderHorizontalBarChart = (canvasId, labels, presupuestado, gastado, colors) => {
            const ctx = document.getElementById(canvasId);
            if (!ctx) return;

            if (hBarChartInstance) {
                hBarChartInstance.destroy();
            }

            hBarChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Presupuestado',
                            data: presupuestado,
                            backgroundColor: 'rgba(99, 102, 241, 0.18)',
                            borderColor: 'rgba(99, 102, 241, 0.8)',
                            borderWidth: 2,
                            borderRadius: 6,
                            borderSkipped: false,
                        },
                        {
                            label: 'Gastado',
                            data: gastado,
                            backgroundColor: colors.map(c => c + 'CC'),
                            borderColor: colors,
                            borderWidth: 2,
                            borderRadius: 6,
                            borderSkipped: false,
                        }
                    ]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                padding: 16,
                                font: { size: 12, weight: '600' },
                                usePointStyle: true,
                                pointStyle: 'rectRounded'
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const value = context.raw;
                                    const datasetIndex = context.datasetIndex;
                                    const categoryIndex = context.dataIndex;
                                    const budget = presupuestado[categoryIndex];
                                    const spent  = gastado[categoryIndex];
                                    const pct = budget > 0 ? ((spent / budget) * 100).toFixed(1) : '0.0';
                                    const formatted = '$' + value.toLocaleString('es-CO');
                                    if (datasetIndex === 0) {
                                        return `  Presupuestado: ${formatted}`;
                                    } else {
                                        const emoji = parseFloat(pct) > 100 ? '⚠️' : parseFloat(pct) > 80 ? '🟡' : '✅';
                                        return [
                                            `  Gastado: ${formatted}`,
                                            `  ${emoji} ${pct}% del presupuesto`
                                        ];
                                    }
                                }
                            },
                            padding: 12,
                            titleFont: { size: 13, weight: '700' },
                            bodyFont: { size: 12 }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: {
                                font: { size: 11 },
                                color: '#6c757d',
                                callback: function(value) {
                                    if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                                    if (value >= 1000)    return '$' + (value / 1000).toFixed(0) + 'k';
                                    return '$' + value;
                                }
                            }
                        },
                        y: {
                            grid: { display: false },
                            ticks: {
                                font: { size: 12, weight: '600' },
                                color: '#495057'
                            }
                        }
                    },
                    animation: {
                        duration: 700,
                        easing: 'easeOutQuart'
                    }
                }
            });
        };
        // ── Gráfica: Barras Apiladas (Categorías histórico) ──
        let stackedChartInstance = null;
        window.renderStackedBarChart = (canvasId, labels, rawDatasets) => {
            const ctx = document.getElementById(canvasId);
            if (!ctx) return;
            
            if (stackedChartInstance) {
                stackedChartInstance.destroy();
            }

            // Mapearemos los colores para que cada categoría tenga un color consistente.
            // Usamos una paleta fresca y extensa de colores vibrantes y modernos.
            const generateColor = (seedName) => {
                const colors = [
                    '#4dc9f6', '#f67019', '#f53794', '#537bc4', '#acc236', 
                    '#166a8f', '#00a950', '#58595b', '#8549ba', '#ffb300',
                    '#c51162', '#3f51b5', '#4caf50', '#009688', '#e91e63'
                ];
                let hash = 0;
                for (let i = 0; i < seedName.length; i++) {
                    hash = seedName.charCodeAt(i) + ((hash << 5) - hash);
                }
                const index = Math.abs(hash % colors.length);
                return colors[index];
            };

            const chartJsDatasets = rawDatasets.map(d => ({
                label: d.label,
                data: d.data,
                backgroundColor: generateColor(d.label),
                borderWidth: 1,
                borderRadius: 4,
                borderColor: 'rgba(255,255,255, 0.5)'
            }));

            stackedChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: chartJsDatasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 15,
                                font: { size: 12 },
                                usePointStyle: true,
                                pointStyle: 'circle'
                            }
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            callbacks: {
                                label: function(context) {
                                    const val = context.raw;
                                    if(val === 0) return null; // Omitir tools en ceros para apilados
                                    return ` ${context.dataset.label}: $${val.toLocaleString('es-CO')}`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            stacked: true,
                            grid: { display: false },
                            ticks: { font: { size: 12, weight: '600' } }
                        },
                        y: {
                            stacked: true,
                            beginAtZero: true,
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: {
                                font: { size: 11 },
                                color: '#6c757d',
                                callback: function(value) {
                                    if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                                    if (value >= 1000)    return '$' + (value / 1000).toFixed(0) + 'k';
                                    return '$' + value;
                                }
                            }
                        }
                    },
                    animation: {
                        duration: 800
                    }
                }
            });
        };
    </script>
</body>

</html>
