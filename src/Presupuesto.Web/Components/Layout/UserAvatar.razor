@using Microsoft.AspNetCore.Components

<div class="user-avatar-wrapper">
    <div class="user-avatar-container" @onclick="ToggleMenu">
        <div class="user-info me-3">
            <span class="user-name">Joann Quintero</span>
            <span class="user-role">Administrador</span>
        </div>
        <div class="avatar-circle">
            <span>JQ</span>
        </div>
    </div>

    @if (isMenuOpen)
    {
        <div class="avatar-dropdown">
            <div class="dropdown-header">
                <strong>Mi Cuenta</strong>
            </div>
            <a href="perfil" class="dropdown-item">
                <i class="bi bi-person me-2"></i> Editar Perfil
            </a>
            <a href="configuracion" class="dropdown-item">
                <i class="bi bi-gear me-2"></i> Configuración
            </a>
            <div class="dropdown-divider"></div>
            <a href="logout" class="dropdown-item text-danger">
                <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
            </a>
        </div>
        <div class="dropdown-overlay" @onclick="ToggleMenu"></div>
    }
</div>

@code {
    private bool isMenuOpen = false;

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }
}
