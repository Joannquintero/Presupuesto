@page "/categorias/crear"
@using Presupuesto.Application.DTOs
@using Presupuesto.Application.Services
@inject ICategoriaPresupuestoService CategoriaService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Crear Categoría - Control de Presupuesto</PageTitle>

<div class="container py-4" style="max-width: 600px;">
    <div class="mb-4">
        <a href="/categorias" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver al listado
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0 fw-bold">
                <i class="bi bi-tag-fill me-2"></i>Nueva Categoría
            </h4>
        </div>
        <div class="card-body p-4">
            <EditForm Model="dto" OnValidSubmit="Guardar" FormName="CreateCategoria">
                <DataAnnotationsValidator />

                <div class="mb-4">
                    <label class="form-label fw-semibold">Nombre de Categoría <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="dto.Nombre" placeholder="Ej: Transporte, Cuidado Personal" />
                    <ValidationMessage For="() => dto.Nombre" class="text-danger small" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger animate__animated animate__shakeX mt-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 fw-bold" disabled="@saving">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-check-lg me-1"></i>Guardar
                    </button>
                    <a href="/categorias" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg me-1"></i>Cancelar
                    </a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private CreateUpdateCategoriaPresupuestoDto dto = new();
    private bool saving = false;
    private string? errorMessage;

    private async Task Guardar()
    {
        saving = true;
        errorMessage = null;

        try
        {
            await CategoriaService.CreateAsync(dto);
            Navigation.NavigateTo("/categorias");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }
}
