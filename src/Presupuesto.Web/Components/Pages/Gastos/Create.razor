@page "/gastos/crear"
@using Presupuesto.Application.DTOs
@using Presupuesto.Application.Services
@using Presupuesto.Domain.Enums
@using Presupuesto.Domain.Entities
@inject IPresupuestoMensualService PresupuestoService
@inject ICategoriaPresupuestoService CategoriaPresupuestoService
@inject IGastoService GastoService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Nuevo Gasto - Control de Presupuesto</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle me-2"></i>Nuevo Gasto
                    </h4>
                </div>
                <div class="card-body">
                    <EditForm Model="gasto" OnValidSubmit="HandleSubmit" FormName="CreateGasto">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Fecha</label>
                            <InputDate class="form-control" @bind-Value="gasto.Fecha" @bind-Value:after="ActualizarDisponible" />
                            <ValidationMessage For="() => gasto.Fecha" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Categoría</label>
                            <InputSelect class="@selectClass" 
                                         ValueExpression="@(() => gasto.CategoriaPresupuestoId)"
                                         Value="@gasto.CategoriaPresupuestoId"
                                         ValueChanged="@((int val) => OnCategoriaChanged(val))">
                                <option value="0">-- Seleccione Categoría --</option>
                                @foreach (var cat in categoriasPresupuesto)
                                {
                                    <option value="@cat.Id">@cat.Nombre</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => gasto.CategoriaPresupuestoId" class="text-danger small" />

                            @if (categoriaEsObligaciones)
                            {
                                <div class="mt-2 animate__animated animate__fadeIn">
                                    <label class="form-label small text-muted">Tipo de Obligación</label>
                                    <InputSelect class="form-select" @bind-Value="gasto.SubCategoria">
                                        <option value="">-- Seleccione Tipo --</option>
                                        @foreach (Categoria sub in Enum.GetValues<Categoria>())
                                        {
                                            <option value="@sub">@sub.ToString()</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => gasto.SubCategoria" class="text-danger small" />
                                </div>
                            }
                            @if (gasto.CategoriaPresupuestoId > 0)
                            {
                                <div class="mt-2 p-2 rounded bg-light border-start border-4 @(montoDisponible.HasValue ? (montoDisponible <= 0 ? "border-danger" : "border-info") : "border-warning") animate__animated animate__fadeIn">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted small">Disponible en categoría:</span>
                                        @if (consultandoDisponible)
                                        {
                                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                        }
                                        else
                                        {
                                            <span class="fw-bold @(montoDisponible.HasValue ? (montoDisponible <= 0 ? "text-danger" : "text-primary") : "text-warning")">
                                                @(montoDisponible.HasValue ? montoDisponible.Value.ToString("C0") : "Sin presupuesto asignado")
                                            </span>
                                        }
                                    </div>
                                    @if (!consultandoDisponible && !montoDisponible.HasValue)
                                    {
                                        <div class="text-warning mt-1" style="font-size: 0.75rem;">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                            Para este mes/año no existe o no tiene fondos para esta categoría.
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Descripción <span class="text-muted fw-normal fs-small">(Opcional)</span></label>
                            <InputText class="form-control" @bind-Value="gasto.Descripcion" placeholder="Ej: Compras en supermercado" />
                            <ValidationMessage For="() => gasto.Descripcion" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-cash-stack me-1"></i>Montos Rápidos
                            </label>
                            <div class="billete-grid">
                                @foreach (var m in montosPredefinidos)
                                {
                                    var colorClass = GetBilleteColor(m);
                                    var isSelected = gasto.Monto == m;
                                    <div class="billete @colorClass @(isSelected ? "billete-selected" : "")"
                                         @onclick="() => SeleccionarMonto(m)">
                                        <div class="billete-pattern"></div>
                                        <div class="billete-corner billete-corner-tl"></div>
                                        <div class="billete-corner billete-corner-tr"></div>
                                        <div class="billete-corner billete-corner-bl"></div>
                                        <div class="billete-corner billete-corner-br"></div>
                                        <div class="billete-content">
                                            <span class="billete-currency">$</span>
                                            <span class="billete-amount">@m.ToString("N0")</span>
                                        </div>
                                        <div class="billete-label">COP</div>
                                        @if (isSelected)
                                        {
                                            <div class="billete-check">
                                                <i class="bi bi-check-circle-fill"></i>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Monto</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light text-primary fw-bold">$</span>
                                <input type="text" class="form-control fw-bold text-primary" 
                                       inputmode="numeric"
                                       onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                                       value="@montoFormateado"
                                       @oninput="OnMontoInput"
                                       placeholder="0" />
                            </div>
                            <ValidationMessage For="() => gasto.Monto" class="text-danger small" />
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger animate__animated animate__shakeX">
                                <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4" disabled="@(saving || gasto.Monto <= 0 || gasto.CategoriaPresupuestoId == 0)">
                                @if (saving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-check-lg me-1"></i>Guardar Gasto
                            </button>
                            <a href="/gastos" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-lg me-1"></i>Cancelar
                            </a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CreateUpdateGastoDto gasto = new();
    private List<CategoriaPresupuesto> categoriasPresupuesto = new();
    private bool saving = false;
    private string? errorMessage;
    private decimal[] montosPredefinidos = { 5000, 10000, 20000, 50000, 100000 };
    private string montoFormateado = "0";

    private string selectClass => $"form-select {(categoriaEsObligaciones ? "mb-2" : "")}";
    private bool categoriaEsObligaciones => categoriasPresupuesto.FirstOrDefault(c => c.Id == gasto.CategoriaPresupuestoId)?.Nombre == "Obligaciones";

    protected override async Task OnInitializedAsync()
    {
        categoriasPresupuesto = await CategoriaPresupuestoService.GetAllAsync();
        await ActualizarDisponible();
    }

    private decimal? montoDisponible;
    private bool consultandoDisponible = false;

    private void OnCategoriaChanged(int id)
    {
        gasto.CategoriaPresupuestoId = id;
        if (!categoriaEsObligaciones)
        {
            gasto.SubCategoria = null;
        }
        _ = ActualizarDisponible();
    }

    private async Task ActualizarDisponible()
    {
        if (gasto.CategoriaPresupuestoId > 0)
        {
            try
            {
                consultandoDisponible = true;
                StateHasChanged();
                montoDisponible = await GastoService.GetDisponibleCategoriaAsync(gasto.Fecha.Year, gasto.Fecha.Month, gasto.CategoriaPresupuestoId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al consultar disponibilidad: {ex.Message}");
                montoDisponible = null;
                errorMessage = $"Error técnico al consultar presupuesto: {ex.Message}";
            }
            finally
            {
                consultandoDisponible = false;
                StateHasChanged();
            }
        }
        else
        {
            montoDisponible = null;
        }
    }

    private void SeleccionarMonto(decimal m)
    {
        gasto.Monto = m;
        montoFormateado = m.ToString("N0", new System.Globalization.CultureInfo("es-CL"));
    }

    private void OnMontoInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        var soloNumeros = new string(val.Where(char.IsDigit).ToArray());

        if (decimal.TryParse(soloNumeros, out var monto))
        {
            gasto.Monto = monto;
            montoFormateado = monto.ToString("N0", new System.Globalization.CultureInfo("es-CL"));
        }
        else
        {
            gasto.Monto = 0;
            montoFormateado = "0";
        }
    }

    private string GetBilleteColor(decimal monto) => monto switch
    {
        5000 => "billete-5k",
        10000 => "billete-10k",
        20000 => "billete-20k",
        50000 => "billete-50k",
        100000 => "billete-100k",
        _ => "billete-5k"
    };

    private async Task HandleSubmit()
    {
        if (gasto.Monto <= 0)
        {
            errorMessage = "El monto debe ser mayor a 0.";
            return;
        }

        if (gasto.CategoriaPresupuestoId == 0)
        {
            errorMessage = "Debe seleccionar una categoría.";
            return;
        }

        if (categoriaEsObligaciones && !gasto.SubCategoria.HasValue)
        {
            errorMessage = "Debe seleccionar el tipo de obligación.";
            return;
        }

        saving = true;
        errorMessage = null;
        try
        {
            await GastoService.CreateAsync(gasto);
            Navigation.NavigateTo("/gastos");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }
}

<style>
    /* ============ BILLETE GRID ============ */
    .billete-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
        gap: 12px;
    }

    /* ============ BILLETE BASE ============ */
    .billete {
        position: relative;
        border-radius: 10px;
        padding: 16px 12px;
        cursor: pointer;
        overflow: hidden;
        border: 2px solid transparent;
        transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12),
                    inset 0 1px 0 rgba(255, 255, 255, 0.2);
        min-height: 80px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .billete:hover {
        transform: translateY(-4px) scale(1.03);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2),
                    inset 0 1px 0 rgba(255, 255, 255, 0.25);
    }

    .billete:active {
        transform: translateY(-1px) scale(1.01);
    }

    /* ============ GUILLOCHÉ PATTERN ============ */
    .billete-pattern {
        position: absolute;
        inset: 0;
        opacity: 0.06;
        background-image:
            repeating-linear-gradient(
                0deg,
                transparent,
                transparent 3px,
                currentColor 3px,
                currentColor 4px
            ),
            repeating-linear-gradient(
                90deg,
                transparent,
                transparent 3px,
                currentColor 3px,
                currentColor 4px
            );
        pointer-events: none;
    }

    /* ============ DECORATIVE CORNERS ============ */
    .billete-corner {
        position: absolute;
        width: 18px;
        height: 18px;
        border-color: currentColor;
        border-style: solid;
        opacity: 0.35;
    }

    .billete-corner-tl {
        top: 5px;
        left: 5px;
        border-width: 2px 0 0 2px;
        border-radius: 4px 0 0 0;
    }

    .billete-corner-tr {
        top: 5px;
        right: 5px;
        border-width: 2px 2px 0 0;
        border-radius: 0 4px 0 0;
    }

    .billete-corner-bl {
        bottom: 5px;
        left: 5px;
        border-width: 0 0 2px 2px;
        border-radius: 0 0 0 4px;
    }

    .billete-corner-br {
        bottom: 5px;
        right: 5px;
        border-width: 0 2px 2px 0;
        border-radius: 0 0 4px 0;
    }

    /* ============ CONTENT ============ */
    .billete-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: baseline;
        gap: 2px;
    }

    .billete-currency {
        font-size: 0.85rem;
        font-weight: 700;
        opacity: 0.8;
    }

    .billete-amount {
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: 0.5px;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    }

    .billete-label {
        position: relative;
        z-index: 1;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.5;
        margin-top: 2px;
    }

    /* ============ CHECK ICON ============ */
    .billete-check {
        position: absolute;
        top: 5px;
        right: 5px;
        z-index: 2;
        font-size: 1.1rem;
        filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.3));
        animation: checkPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes checkPop {
        0% { transform: scale(0); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }

    /* ============ SELECTED STATE ============ */
    .billete-selected {
        transform: translateY(-3px) scale(1.04);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25),
                    inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    .billete-selected .billete-corner {
        opacity: 0.6;
    }

    /* ============ COLOR THEMES ============ */

    /* $5.000 - Verde suave */
    .billete-5k {
        background: linear-gradient(135deg, #2d8a4e, #34a853, #43b563);
        color: #e8f5e9;
    }
    .billete-5k.billete-selected {
        border-color: #1b5e20;
        box-shadow: 0 6px 20px rgba(45, 138, 78, 0.45),
                    inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    /* $10.000 - Rojo terracota */
    .billete-10k {
        background: linear-gradient(135deg, #c0392b, #d44637, #e74c3c);
        color: #fce4ec;
    }
    .billete-10k.billete-selected {
        border-color: #7f1d1d;
        box-shadow: 0 6px 20px rgba(192, 57, 43, 0.45),
                    inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    /* $20.000 - Naranja dorado */
    .billete-20k {
        background: linear-gradient(135deg, #d4820a, #e8960f, #f0a416);
        color: #fff8e1;
    }
    .billete-20k.billete-selected {
        border-color: #7c4a03;
        box-shadow: 0 6px 20px rgba(212, 130, 10, 0.45),
                    inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    /* $50.000 - Azul profundo */
    .billete-50k {
        background: linear-gradient(135deg, #1a3a6b, #1e5299, #2471cc);
        color: #e3f2fd;
    }
    .billete-50k.billete-selected {
        border-color: #0d1f3c;
        box-shadow: 0 6px 20px rgba(26, 58, 107, 0.45),
                    inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    /* $100.000 - Púrpura premium */
    .billete-100k {
        background: linear-gradient(135deg, #4a1a6b, #6a2c91, #8234b0);
        color: #f3e5f5;
    }
    .billete-100k.billete-selected {
        border-color: #2d0f41;
        box-shadow: 0 6px 20px rgba(74, 26, 107, 0.5),
                    inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    /* ============ RESPONSIVE ============ */
    @@media (max-width: 480px) {
        .billete-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .billete-amount {
            font-size: 1.05rem;
        }
    }
</style>

