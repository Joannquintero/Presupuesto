@page "/gastos/editar/{Id:int}"
@using Presupuesto.Application.DTOs
@using Presupuesto.Application.Services
@using Presupuesto.Domain.Enums
@inject IGastoService GastoService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Editar Gasto - Control de Presupuesto</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            @if (loading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
            }
            else if (notFound)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Gasto no encontrado.
                    <a href="/gastos" class="alert-link">Volver al listado</a>
                </div>
            }
            else
            {
                <div class="card shadow">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0">
                            <i class="bi bi-pencil me-2"></i>Editar Gasto
                        </h4>
                    </div>
                    <div class="card-body">
                        <EditForm Model="gasto" OnValidSubmit="HandleSubmit" FormName="EditGasto">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-danger" />

                            <div class="mb-3">
                                <label class="form-label">Fecha</label>
                                <InputDate class="form-control" @bind-Value="gasto.Fecha" />
                                <ValidationMessage For="() => gasto.Fecha" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Categoría</label>
                                <InputSelect class="form-select" @bind-Value="gasto.Categoria">
                                    @foreach (Categoria cat in Enum.GetValues<Categoria>())
                                    {
                                        <option value="@cat">@cat.ToString()</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => gasto.Categoria" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Descripción</label>
                                <InputText class="form-control" @bind-Value="gasto.Descripcion" />
                                <ValidationMessage For="() => gasto.Descripcion" class="text-danger" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Monto</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <InputNumber class="form-control" @bind-Value="gasto.Monto" step="0.01" />
                                </div>
                                <ValidationMessage For="() => gasto.Monto" class="text-danger" />
                            </div>

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger">@errorMessage</div>
                            }

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-warning" disabled="@saving">
                                    @if (saving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-check-lg me-1"></i>Actualizar
                                </button>
                                <a href="/gastos" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-lg me-1"></i>Cancelar
                                </a>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private CreateUpdateGastoDto gasto = new();
    private bool loading = true;
    private bool notFound = false;
    private bool saving = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var existing = await GastoService.GetByIdAsync(Id);
        if (existing is null)
        {
            notFound = true;
        }
        else
        {
            gasto = new CreateUpdateGastoDto
            {
                Fecha = existing.Fecha,
                Categoria = existing.Categoria,
                Descripcion = existing.Descripcion,
                Monto = existing.Monto
            };
        }
        loading = false;
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;
        try
        {
            await GastoService.UpdateAsync(Id, gasto);
            Navigation.NavigateTo("/gastos");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al actualizar: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }
}
