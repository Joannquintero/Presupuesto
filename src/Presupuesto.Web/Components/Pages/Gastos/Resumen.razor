@page "/gastos/resumen"
@using Presupuesto.Application.DTOs
@using Presupuesto.Application.Services
@using Presupuesto.Domain.Enums
@inject IGastoService GastoService
@inject IPresupuestoMensualService PresupuestoService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Resumen Mensual - Control de Presupuesto</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-6">
                <i class="bi bi-graph-up me-2"></i>Resumen Mensual
            </h1>
        </div>
    </div>

    <!-- Selector de mes -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col">
                            <select class="form-select" @bind="selectedAnio" @bind:after="CargarResumen">
                                @for (int i = DateTime.Now.Year; i >= DateTime.Now.Year - 5; i--)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                        </div>
                        <div class="col">
                            <select class="form-select" @bind="selectedMes" @bind:after="CargarResumen">
                                @foreach (var mes in meses)
                                {
                                    <option value="@mes.Key">@mes.Value</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (resumen is not null)
    {
        <!-- Cards de resumen -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card bg-primary text-white shadow">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-uppercase mb-1 opacity-75">Total del Mes</h6>
                                <h2 class="mb-0">@resumen.TotalMes.ToString("C2")</h2>
                            </div>
                            <i class="bi bi-cash-coin fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-success text-white shadow">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-uppercase mb-1 opacity-75">Categorías</h6>
                                <h2 class="mb-0">@resumen.GastosPorCategoria.Count</h2>
                            </div>
                            <i class="bi bi-tags fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-info text-white shadow">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-uppercase mb-1 opacity-75">Período</h6>
                                <h2 class="mb-0 text-capitalize">@resumen.MesNombre @resumen.Anio</h2>
                            </div>
                            <i class="bi bi-calendar3 fs-1 opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Gráfica -->
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Gastos por Categoría</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="chartCategorias" width="400" height="300"></canvas>
                    </div>
                </div>
            </div>

            <!-- Tabla de desglose -->
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Desglose por Categoría</h5>
                    </div>
                    <div class="card-body p-0">

                        @* ===== Vista Desktop: Tabla clásica ===== *@
                        <div class="desglose-desktop">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Categoría</th>
                                        <th class="text-center">Cantidad</th>
                                        <th class="text-end">Total</th>
                                        <th class="text-end">%</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in resumen.GastosPorCategoria)
                                    {
                                        var porcentaje = resumen.TotalMes > 0 ? (item.Total / resumen.TotalMes * 100) : 0;
                                        <tr>
                                            <td>
                                                <span class="badge @GetCategoriaBadgeClass(item.CategoriaNombre)">
                                                    @item.CategoriaNombre
                                                </span>
                                            </td>
                                            <td class="text-center">@item.Cantidad</td>
                                            <td class="text-end fw-bold">@item.Total.ToString("C2")</td>
                                            <td class="text-end">@porcentaje.ToString("F1")%</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <th>Total</th>
                                        <th class="text-center">@resumen.GastosPorCategoria.Sum(g => g.Cantidad)</th>
                                        <th class="text-end text-success">@resumen.TotalMes.ToString("C2")</th>
                                        <th class="text-end">100%</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        @* ===== Vista Móvil: Tarjetas apiladas ===== *@
                        <div class="desglose-mobile">
                            @foreach (var item in resumen.GastosPorCategoria)
                            {
                                var porcentaje = resumen.TotalMes > 0 ? (item.Total / resumen.TotalMes * 100) : 0;
                                <div class="desglose-card">
                                    <div class="desglose-card-header">
                                        <span class="badge @GetCategoriaBadgeClass(item.CategoriaNombre)">
                                            @item.CategoriaNombre
                                        </span>
                                        <span class="desglose-card-cantidad">
                                            @item.Cantidad @(item.Cantidad == 1 ? "gasto" : "gastos")
                                        </span>
                                    </div>
                                    <div class="desglose-card-body">
                                        <span class="desglose-card-total">@item.Total.ToString("C2")</span>
                                        <span class="desglose-card-pct">@porcentaje.ToString("F1")%</span>
                                    </div>
                                    <div class="desglose-bar-track">
                                        <div class="desglose-bar-fill @GetCategoriaBarClass(item.CategoriaNombre)"
                                             style="width: @porcentaje.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                    </div>
                                </div>
                            }
                            <!-- Total móvil -->
                            <div class="desglose-card desglose-card-total-row">
                                <div class="desglose-card-header">
                                    <span class="fw-bold text-muted">
                                        <i class="bi bi-calculator me-1"></i>Total
                                    </span>
                                    <span class="desglose-card-cantidad">
                                        @resumen.GastosPorCategoria.Sum(g => g.Cantidad) gastos
                                    </span>
                                </div>
                                <div class="desglose-card-body">
                                    <span class="desglose-card-total text-success">@resumen.TotalMes.ToString("C2")</span>
                                    <span class="desglose-card-pct">100%</span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- Gráfica: Presupuesto vs Gasto Real -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <h5 class="mb-0">
                            <i class="bi bi-bar-chart-steps me-2 text-indigo"></i>Presupuesto vs Gasto Real
                        </h5>
                        <span class="badge bg-secondary bg-opacity-10 text-dark fw-semibold">
                            @resumen.MesNombre @resumen.Anio
                        </span>
                    </div>
                    @if (presupuestoMensual is null)
                    {
                        <div class="card-body">
                            <div class="alert alert-warning mb-0">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                No hay presupuesto configurado para este período.
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card-body chart-hbar-wrapper">
                            <canvas id="chartHBarras"></canvas>
                        </div>
                        <!-- Mini tabla de estado por categoría -->
                        <div class="card-footer bg-transparent px-4 pb-3 pt-2">
                            <div class="row g-2">
                                @foreach (var dist in presupuestoMensual.Distribuciones)
                                {
                                    var gastoReal = resumen.GastosPorCategoria
                                        .FirstOrDefault(g => g.CategoriaPresupuestoId == dist.CategoriaPresupuestoId);
                                    var gastado = gastoReal?.Total ?? 0m;
                                    var pct = dist.Monto > 0 ? (Math.Round(gastado / dist.Monto * 100, 1)) : 0m;
                                    var pctWidth = Math.Min(pct, 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                                    
                                    string modifier = pct > 100 ? "danger" : pct > 80 ? "warning" : "ok";
                                    string cardClass = "status-card status-" + modifier;
                                    string fillClass = "status-bar-fill status-" + modifier;
                                    string iconBase = pct > 100 ? "bi-exclamation-triangle-fill" : pct > 80 ? "bi-exclamation-circle-fill" : "bi-check-circle-fill";
                                    string iconClass = "bi " + iconBase;

                                    <div class="col-md-6 col-lg-3">
                                        <div class="@cardClass">
                                            <div class="status-card-header">
                                                <span class="fw-semibold small">@dist.CategoriaNombre</span>
                                                <i class="@iconClass"></i>
                                            </div>
                                            <div class="status-bar-track">
                                                <div class="@fillClass" style="width: @(pctWidth)%"></div>
                                            </div>
                                            <div class="d-flex justify-content-between mt-1">
                                                <span class="small text-muted">@gastado.ToString("C0")</span>
                                                <span class="small fw-semibold">@pct.ToString("F0")% de @dist.Monto.ToString("C0")</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            No hay datos para el período seleccionado.
        </div>
    }
</div>

@code {
    private ResumenMensualDto? resumen;
    private PresupuestoMensualDto? presupuestoMensual;
    private bool loading = true;
    private int selectedAnio = DateTime.Now.Year;
    private int selectedMes = DateTime.Now.Month;
    private bool chartsRendered = false;

    private readonly Dictionary<int, string> meses = new()
    {
        { 1, "Enero" }, { 2, "Febrero" }, { 3, "Marzo" }, { 4, "Abril" },
        { 5, "Mayo" }, { 6, "Junio" }, { 7, "Julio" }, { 8, "Agosto" },
        { 9, "Septiembre" }, { 10, "Octubre" }, { 11, "Noviembre" }, { 12, "Diciembre" }
    };

    protected override async Task OnInitializedAsync()
    {
        await CargarResumen();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (resumen is not null && resumen.GastosPorCategoria.Any() && !chartsRendered)
        {
            chartsRendered = true;
            await RenderChart();
            if (presupuestoMensual is not null)
                await RenderHorizontalBarChart();
        }
    }

    private async Task CargarResumen()
    {
        loading = true;
        chartsRendered = false;
        try
        {
            resumen = await GastoService.GetResumenMensualAsync(selectedAnio, selectedMes);

            // Cargar el presupuesto del período seleccionado
            var presupuestos = await PresupuestoService.GetByFilterAsync(selectedAnio, selectedMes, null);
            presupuestoMensual = presupuestos.FirstOrDefault();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar resumen: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task RenderChart()
    {
        if (resumen is null) return;

        var labels = resumen.GastosPorCategoria.Select(g => g.CategoriaNombre).ToArray();
        var data = resumen.GastosPorCategoria.Select(g => (double)g.Total).ToArray();
        var colors = resumen.GastosPorCategoria.Select(g => GetCategoriaColor(g.CategoriaNombre)).ToArray();

        await JS.InvokeVoidAsync("renderPieChart", "chartCategorias", labels, data, colors);
    }

    private async Task RenderHorizontalBarChart()
    {
        if (resumen is null || presupuestoMensual is null) return;

        // Alinear datos: una entrada por distribución del presupuesto
        var distribuciones = presupuestoMensual.Distribuciones;
        var labels     = distribuciones.Select(d => d.CategoriaNombre).ToArray();
        var budget     = distribuciones.Select(d => (double)d.Monto).ToArray();
        var spent      = distribuciones.Select(d =>
        {
            var g = resumen.GastosPorCategoria.FirstOrDefault(x => x.CategoriaPresupuestoId == d.CategoriaPresupuestoId);
            return g is null ? 0.0 : (double)g.Total;
        }).ToArray();
        var colors     = distribuciones.Select(d => GetCategoriaColor(d.CategoriaNombre)).ToArray();

        await JS.InvokeVoidAsync("renderHorizontalBarChart", "chartHBarras", labels, budget, spent, colors);
    }

    private string GetCategoriaBadgeClass(string nombre) => nombre switch
    {
        "Obligaciones" => "bg-success",
        "Gustos personales" => "bg-primary",
        "Metas-Ahorro" => "bg-info",
        "Imprevistos" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private string GetCategoriaColor(string nombre) => nombre switch
    {
        "Obligaciones" => "#198754",
        "Gustos personales" => "#0d6efd",
        "Metas-Ahorro" => "#0dcaf0",
        "Imprevistos" => "#ffc107",
        _ => "#6c757d"
    };

    private string GetCategoriaBarClass(string nombre) => nombre switch
    {
        "Obligaciones" => "bar-success",
        "Gustos personales" => "bar-primary",
        "Metas-Ahorro" => "bar-info",
        "Imprevistos" => "bar-warning",
        _ => "bar-secondary"
    };
}

<style>
    /* ===== Visibility toggle ===== */
    .desglose-mobile {
        display: none;
    }
    .desglose-desktop {
        display: block;
    }

    @@media (max-width: 767.98px) {
        .desglose-desktop {
            display: none;
        }
        .desglose-mobile {
            display: block;
            padding: 12px;
        }
    }

    /* ===== Mobile card styles ===== */
    .desglose-card {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 10px;
        border: 1px solid #e9ecef;
        transition: box-shadow 0.2s ease;
    }

    .desglose-card:hover {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .desglose-card:last-child {
        margin-bottom: 0;
    }

    .desglose-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .desglose-card-cantidad {
        font-size: 0.8rem;
        color: #6c757d;
        font-weight: 500;
    }

    .desglose-card-body {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 8px;
    }

    .desglose-card-total {
        font-size: 1.2rem;
        font-weight: 700;
        color: #212529;
    }

    .desglose-card-pct {
        font-size: 0.9rem;
        font-weight: 600;
        color: #495057;
        background: #e9ecef;
        padding: 2px 8px;
        border-radius: 12px;
    }

    /* ===== Progress bar ===== */
    .desglose-bar-track {
        height: 6px;
        background: #dee2e6;
        border-radius: 3px;
        overflow: hidden;
    }

    .desglose-bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .bar-success  { background: #198754; }
    .bar-primary  { background: #0d6efd; }
    .bar-info     { background: #0dcaf0; }
    .bar-warning  { background: #ffc107; }
    .bar-secondary { background: #6c757d; }

    /* ===== Total row ===== */
    .desglose-card-total-row {
        background: #e8f5e9;
        border-color: #c8e6c9;
    }

    /* ===== Horizontal Bar Chart ===== */
    .chart-hbar-wrapper {
        position: relative;
        height: 280px;
    }

    .text-indigo { color: #6366f1; }

    /* ===== Status Cards ===== */
    .status-card {
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid #e9ecef;
        background: #f8f9fa;
    }

    .status-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .status-bar-track {
        height: 6px;
        background: #dee2e6;
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 4px;
    }

    .status-bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.6s ease;
    }

    /* OK: verde, uso menor a 80% */
    .status-ok { border-color: #c8e6c9; }
    .status-ok .status-bar-fill { background: #198754; }
    .status-ok .bi { color: #198754; }

    /* Warning: amarillo, uso 80-100% */
    .status-warning { border-color: #fff3cd; }
    .status-warning .status-bar-fill { background: #fd7e14; }
    .status-warning .bi { color: #fd7e14; }

    /* Danger: rojo, uso mayor a 100% */
    .status-danger { border-color: #f5c2c7; }
    .status-danger .status-bar-fill { background: #dc3545; }
    .status-danger .bi { color: #dc3545; }
</style>

