@page "/"

<PageTitle>Control de Gastos Personales</PageTitle>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">
            <i class="bi bi-wallet2 me-3"></i>Control de Gastos
        </h1>
        <p class="lead text-muted">Administra tus finanzas personales de manera sencilla</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4 d-flex flex-column">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3 mx-auto">
                        <i class="bi bi-list-ul fs-1 text-primary"></i>
                    </div>
                    <h5 class="card-title">Ver Gastos</h5>
                    <p class="card-text text-muted mb-4">Consulta y administra todos tus gastos registrados.</p>
                    <a href="/gastos" class="btn btn-primary w-100 mt-auto">
                        <i class="bi bi-arrow-right me-1"></i>Ir a Gastos
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4 d-flex flex-column">
                    <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3 mx-auto">
                        <i class="bi bi-plus-circle fs-1 text-success"></i>
                    </div>
                    <h5 class="card-title">Nuevo Gasto</h5>
                    <p class="card-text text-muted mb-4">Registra un nuevo gasto de forma rápida y sencilla.</p>
                    <a href="/gastos/crear" class="btn btn-success w-100 mt-auto">
                        <i class="bi bi-plus-lg me-1"></i>Agregar
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4 d-flex flex-column">
                    <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3 mx-auto">
                        <i class="bi bi-calendar-plus fs-1 text-warning"></i>
                    </div>
                    <h5 class="card-title">Presupuestos</h5>
                    <p class="card-text text-muted mb-4">Define tu presupuesto mensual y distribuye tus fondos.</p>
                    <a href="/presupuesto-mensual" class="btn btn-warning text-dark w-100 mt-auto">
                        <i class="bi bi-list-check me-1"></i>Ver Presupuestos
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <div class="card-body text-center p-4 d-flex flex-column">
                    <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3 mx-auto">
                        <i class="bi bi-graph-up fs-1 text-info"></i>
                    </div>
                    <h5 class="card-title">Resumen</h5>
                    <p class="card-text text-muted mb-4">Visualiza el resumen mensual de tus gastos.</p>
                    <a href="/gastos/resumen" class="btn btn-info text-white w-100 mt-auto">
                        <i class="bi bi-bar-chart me-1"></i>Ver Resumen
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>
