@page "/presupuesto-mensual/crear"
@using Presupuesto.Application.DTOs
@using Presupuesto.Application.Services
@using Presupuesto.Domain.Entities
@inject IPresupuestoMensualService PresupuestoService
@inject ICategoriaPresupuestoService CategoriaService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Nuevo Presupuesto - Control de Presupuesto</PageTitle>

<div class="container py-4" style="max-width: 800px;">
    <div class="mb-4">
        <a href="/presupuesto-mensual" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver al listado
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <h4 class="mb-0">
                <i class="bi bi-plus-circle me-2 text-primary"></i>Nuevo Presupuesto Mensual
            </h4>
        </div>
        <div class="card-body">
            <EditForm Model="dto" OnValidSubmit="Guardar" FormName="create-presupuesto">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <!-- Año -->
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Año</label>
                        <input type="number" class="form-control bg-light" value="@dto.Anio" readonly />
                        <div class="form-text">El año se establece automáticamente.</div>
                    </div>

                    <!-- Mes -->
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Mes <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="dto.Mes">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var mes in Meses)
                            {
                                <option value="@mes.Key">@mes.Value</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => dto.Mes" class="text-danger small" />
                    </div>

                    <!-- Monto -->
                    <div class="col-12">
                        <label class="form-label fw-semibold">Monto Total <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="text" class="form-control" inputmode="numeric"
                                   value="@montoTexto"
                                   @oninput="OnMontoInput"
                                   placeholder="0" />
                        </div>
                        <ValidationMessage For="() => dto.Monto" class="text-danger small" />
                    </div>

                    <!-- Concepto -->
                    <div class="col-12">
                        <label class="form-label fw-semibold">Concepto <span class="text-muted small">(opcional)</span></label>
                        <InputText class="form-control" @bind-Value="dto.Concepto"
                                   maxlength="200"
                                   placeholder="Ej: Ahorro para vacaciones, Gastos fijos del hogar..." />
                        <div class="d-flex justify-content-between">
                            <ValidationMessage For="() => dto.Concepto" class="text-danger small" />
                            <span class="text-muted small ms-auto">@((dto.Concepto?.Length ?? 0))/200</span>
                        </div>
                    </div>
                </div>

                <!-- Sección de Distribución -->
                <div class="mt-4 p-3 border rounded bg-light">
                    <h5 class="mb-3">Distribución del Presupuesto por Categoría</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40%">Categoría</th>
                                    <th style="width: 25%">Porcentaje (%)</th>
                                    <th style="width: 25%">Monto Calculado</th>
                                    <th style="width: 10%"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dist in dto.Distribuciones)
                                {
                                    <tr>
                                        <td>
                                            @if (dist.CategoriaNombre == "Obligaciones")
                                            {
                                                <div class="form-control bg-light">@dist.CategoriaNombre</div>
                                            }
                                            else
                                            {
                                                <select class="form-select" @bind="dist.CategoriaPresupuestoId">
                                                    @foreach (var cat in categorias.Where(c => c.Nombre != "Obligaciones"))
                                                    {
                                                        <option value="@cat.Id">@cat.Nombre</option>
                                                    }
                                                </select>
                                            }
                                        </td>
                                        <td>
                                            <div class="input-group">
                                                <input type="number" class="form-control" 
                                                       value="@((int)dist.Porcentaje)" 
                                                       @oninput="(e) => OnPorcentajeInput(dist, e)"
                                                       min="0" max="100" step="1" />
                                                <span class="input-group-text">%</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="input-group">
                                                <span class="input-group-text bg-light">$</span>
                                                <span class="form-control bg-light text-end">@dist.Monto.ToString("N0", new System.Globalization.CultureInfo("es-CL"))</span>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            @if (dist.CategoriaNombre != "Obligaciones")
                                            {
                                                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoverDistribucion(dist)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot @ref="footerElement">
                                <tr class="fw-bold @(TotalPorcentaje == 100 ? "table-success" : "table-warning")">
                                    <td>TOTAL</td>
                                    <td>@TotalPorcentaje %</td>
                                    <td class="text-end">$ @dto.Distribuciones.Sum(d => d.Monto).ToString("N0", new System.Globalization.CultureInfo("es-CL"))</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AgregarDistribucion">
                        <i class="bi bi-plus-lg me-1"></i>Agregar Categoría
                    </button>
                    
                    @if (TotalPorcentaje != 100)
                    {
                        <div class="text-danger small mt-2">
                            <i class="bi bi-exclamation-circle me-1"></i>La suma de los porcentajes debe ser exactamente 100%. Actual: @TotalPorcentaje%
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger mt-3">
                        <i class="bi bi-exclamation-triangle me-1"></i>@errorMessage
                    </div>
                }

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary" disabled="@(saving || TotalPorcentaje != 100)">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg me-1"></i>
                        }
                        Guardar Presupuesto
                    </button>
                    <a href="/presupuesto-mensual" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private CreateUpdatePresupuestoMensualDto dto = new();
    private List<CategoriaPresupuesto> categorias = new();
    private bool saving = false;
    private string? errorMessage;
    private ElementReference footerElement;

    private static readonly Dictionary<int, string> Meses = new()
    {
        { 1, "Enero" }, { 2, "Febrero" }, { 3, "Marzo" }, { 4, "Abril" },
        { 5, "Mayo" }, { 6, "Junio" }, { 7, "Julio" }, { 8, "Agosto" },
        { 9, "Septiembre" }, { 10, "Octubre" }, { 11, "Noviembre" }, { 12, "Diciembre" }
    };

    private string montoTexto = string.Empty;
    private decimal TotalPorcentaje => dto.Distribuciones.Sum(d => d.Porcentaje);

    protected override async Task OnInitializedAsync()
    {
        dto.Anio = DateTime.Now.Year;
        dto.Mes = DateTime.Now.Month;
        
        categorias = await CategoriaService.GetAllAsync();
        
        // Inicializar con "Obligaciones" al 100%
        var obligacion = categorias.FirstOrDefault(c => c.Nombre == "Obligaciones");
        if (obligacion != null)
        {
            dto.Distribuciones.Add(new DistribucionPresupuestoDto
            {
                CategoriaPresupuestoId = obligacion.Id,
                CategoriaNombre = obligacion.Nombre,
                Porcentaje = 100,
                Monto = 0
            });
        }
    }

    private void AgregarDistribucion()
    {
        var primeraNoObligacion = categorias.FirstOrDefault(c => c.Nombre != "Obligaciones");
        if (primeraNoObligacion != null)
        {
            dto.Distribuciones.Add(new DistribucionPresupuestoDto
            {
                CategoriaPresupuestoId = primeraNoObligacion.Id,
                CategoriaNombre = primeraNoObligacion.Nombre,
                Porcentaje = 0,
                Monto = 0
            });
        }
    }

    private void RemoverDistribucion(DistribucionPresupuestoDto dist)
    {
        dto.Distribuciones.Remove(dist);
    }

    private void OnPorcentajeInput(DistribucionPresupuestoDto dist, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            dist.Porcentaje = Math.Clamp(Math.Round(val, 0), 0, 100);
            RecalcularMontos();
        }
    }

    private void RecalcularMontos()
    {
        foreach (var dist in dto.Distribuciones)
        {
            dist.Monto = Math.Round(dto.Monto * (dist.Porcentaje / 100m), 2);
        }
    }

    private async Task Guardar()
    {
        if (TotalPorcentaje != 100)
        {
            errorMessage = "La suma de porcentajes debe ser 100%";
            return;
        }

        saving = true;
        errorMessage = null;
        try
        {
            await PresupuestoService.CreateAsync(dto);
            Navigation.NavigateTo("/presupuesto-mensual");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private void OnMontoInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? string.Empty;
        var solo = new string(raw.Where(char.IsDigit).ToArray());

        if (string.IsNullOrEmpty(solo))
        {
            dto.Monto = 0;
            montoTexto = string.Empty;
            RecalcularMontos();
            return;
        }

        if (long.TryParse(solo, out var valor))
        {
            dto.Monto = valor;
            montoTexto = valor.ToString("N0", new System.Globalization.CultureInfo("es-CL"));
            RecalcularMontos();
        }
    }
}
