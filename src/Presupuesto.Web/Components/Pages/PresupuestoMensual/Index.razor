@page "/presupuesto-mensual"
@using Presupuesto.Application.DTOs
@using Presupuesto.Application.Services
@using Presupuesto.Domain.Enums
@inject IPresupuestoMensualService PresupuestoService
@inject ISaldoPresupuestoService SaldoService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Presupuesto Mensual - Control de Presupuesto</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-6">
                <i class="bi bi-calendar-check me-2"></i>Presupuesto Mensual
            </h1>
        </div>
        <div class="col-auto">
            <a href="/presupuesto-mensual/crear" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Nuevo Presupuesto
            </a>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Año</label>
                    <select class="form-select" @bind="filtroAnio" @bind:after="Filtrar">
                        <option value="">Todos</option>
                        @for (int i = DateTime.Now.Year + 1; i >= DateTime.Now.Year - 5; i--)
                        {
                            <option value="@i">@i</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Mes</label>
                    <select class="form-select" @bind="filtroMes" @bind:after="Filtrar">
                        <option value="">Todos</option>
                        @foreach (var mes in Meses)
                        {
                            <option value="@mes.Key">@mes.Value</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Buscar por concepto</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Ej: Ahorro, Arriendo..."
                               @bind="busqueda" @bind:after="Filtrar" />
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="LimpiarFiltros">
                        <i class="bi bi-x-circle me-1"></i>Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                @if (presupuestos.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No se encontraron presupuestos.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Año</th>
                                    <th>Mes</th>
                                    <th class="text-end">Presupuesto</th>
                                    <th class="text-end">Saldo Actual</th>
                                    <th>Concepto</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in presupuestos)
                                {
                                    var presupuestoId = p.Id;
                                    var saldoColor = p.SaldoActual >= p.Monto
                                        ? "text-success"
                                        : p.SaldoActual > 0 ? "text-warning" : "text-danger";
                                    <tr>
                                        <td>@p.Anio</td>
                                        <td>@p.MesNombre</td>
                                        <td class="text-end fw-semibold">$ @p.Monto.ToString("N0")</td>
                                        <td class="text-end fw-semibold @saldoColor">
                                            $ @p.SaldoActual.ToString("N0")
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(p.Concepto))
                                            {
                                                <span>@p.Concepto</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">Sin concepto</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-success me-1"
                                                    style="width:32px;height:32px;padding:0;"
                                                    title="Ajustar saldo"
                                                    @onclick="() => AbrirModalSaldo(presupuestoId)">
                                                ±
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary me-1"
                                                    style="width:32px;height:32px;padding:0;"
                                                    title="Editar"
                                                    @onclick="() => EditarPresupuesto(presupuestoId)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    style="width:32px;height:32px;padding:0;"
                                                    title="Eliminar"
                                                    @onclick="() => MostrarModalEliminar(presupuestoId)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="text-muted small mt-2">
                        Total: <strong>@presupuestos.Count</strong> registro(s)
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Modal: Ajustar Saldo -->
@if (showSaldoModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-plus-minus me-2 text-success"></i>Ajustar Saldo
                    </h5>
                    <button type="button" class="btn-close" @onclick="CerrarModalSaldo"></button>
                </div>
                <div class="modal-body">

                    <!-- Historial de movimientos -->
                    @if (historialSaldos.Count > 0)
                    {
                        <h6 class="mb-2 fw-semibold">Movimientos anteriores</h6>
                        <div class="table-responsive mb-4">
                            <table class="table table-sm table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Tipo</th>
                                        <th class="text-end">Monto</th>
                                        <th>Concepto</th>
                                        <th class="text-center">Quitar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in historialSaldos)
                                    {
                                        var saldoId = s.Id;
                                        <tr>
                                            <td class="text-nowrap">@s.Fecha.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <span class="badge @(s.Tipo == TipoMovimiento.Agregar ? "bg-success" : "bg-danger")">
                                                    @s.TipoTexto
                                                </span>
                                            </td>
                                            <td class="text-end fw-semibold">$ @s.Monto.ToString("N0")</td>
                                            <td>@(s.Concepto ?? "-")</td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => EliminarSaldo(saldoId)">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- Formulario nuevo movimiento -->
                    <h6 class="fw-semibold mb-3">Nuevo movimiento</h6>
                    <EditForm Model="dtoSaldo" OnValidSubmit="GuardarSaldo" FormName="form-saldo">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <!-- Tipo -->
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Tipo <span class="text-danger">*</span></label>
                                <InputSelect class="form-select" @bind-Value="dtoSaldo.Tipo">
                                    <option value="@TipoMovimiento.Agregar">Agregar</option>
                                    <option value="@TipoMovimiento.Quitar">Quitar</option>
                                </InputSelect>
                                <ValidationMessage For="() => dtoSaldo.Tipo" class="text-danger small" />
                            </div>

                            <!-- Monto -->
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Monto <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="text" class="form-control" 
                                           inputmode="numeric"
                                           onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                                           value="@montoSaldoTexto"
                                           @oninput="OnMontoSaldoInput"
                                           placeholder="0" />
                                </div>
                                <ValidationMessage For="() => dtoSaldo.Monto" class="text-danger small" />
                            </div>

                            <!-- Concepto -->
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Concepto</label>
                                <InputText class="form-control" @bind-Value="dtoSaldo.Concepto"
                                           maxlength="200"
                                           placeholder="Nota..." />
                                <ValidationMessage For="() => dtoSaldo.Concepto" class="text-danger small" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorSaldo))
                        {
                            <div class="alert alert-danger mt-3 mb-0">
                                <i class="bi bi-exclamation-triangle me-1"></i>@errorSaldo
                            </div>
                        }

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-success" disabled="@savingSaldo">
                                @if (savingSaldo)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg me-1"></i>
                                }
                                Guardar movimiento
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CerrarModalSaldo">
                                Cerrar
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de confirmación de eliminación de presupuesto -->
@if (showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showDeleteModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-0">¿Está seguro de eliminar este presupuesto? Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="() => showDeleteModal = false">Cancelar</button>
                    <button type="button" class="btn btn-danger px-4" @onclick="ConfirmarEliminar">Eliminar</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal de confirmación para Ajuste de Saldo -->
@if (showConfirmSaldoModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Atención
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => showConfirmSaldoModal = false"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <p class="fs-5 mb-2">¿Confirmar ajuste de saldo?</p>
                    <div class="alert alert-info border-0 py-2 small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Este cambio afectará los valores de la <strong>distribución mensual</strong> y recalculará los porcentajes automáticamente.
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => showConfirmSaldoModal = false">Cancelar</button>
                    <button type="button" class="btn btn-primary px-4" @onclick="ConfirmarGuardarSaldo">
                        Confirmar y Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── Listado ──────────────────────────────────────────────────────────────
    private List<PresupuestoMensualDto> presupuestos = new();
    private bool loading = true;
    private string? filtroAnio;
    private string? filtroMes;
    private string? busqueda;

    // ── Eliminación ──────────────────────────────────────────────────────────
    private bool showDeleteModal = false;
    private int idToDelete;

    // ── Modal Saldo ──────────────────────────────────────────────────────────
    private bool showSaldoModal = false;
    private int presupuestoIdSaldo;
    private CreateSaldoPresupuestoDto dtoSaldo = new();
    private List<SaldoPresupuestoDto> historialSaldos = new();
    private string montoSaldoTexto = string.Empty;
    private bool savingSaldo = false;
    private bool showConfirmSaldoModal = false;
    private string? errorSaldo;

    private static readonly Dictionary<int, string> Meses = new()
    {
        { 1, "Enero" }, { 2, "Febrero" }, { 3, "Marzo" }, { 4, "Abril" },
        { 5, "Mayo" }, { 6, "Junio" }, { 7, "Julio" }, { 8, "Agosto" },
        { 9, "Septiembre" }, { 10, "Octubre" }, { 11, "Noviembre" }, { 12, "Diciembre" }
    };

    protected override async Task OnInitializedAsync()
    {
        filtroAnio = DateTime.Now.Year.ToString();
        filtroMes = null;
        await Filtrar();
    }

    private async Task Filtrar()
    {
        loading = true;
        try
        {
            int? anio = string.IsNullOrEmpty(filtroAnio) ? null : int.Parse(filtroAnio);
            int? mes  = string.IsNullOrEmpty(filtroMes)  ? null : int.Parse(filtroMes);
            presupuestos = await PresupuestoService.GetByFilterAsync(anio, mes, busqueda);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al filtrar presupuestos: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LimpiarFiltros()
    {
        filtroAnio = null;
        filtroMes  = null;
        busqueda   = null;
        await Filtrar();
    }

    private void MostrarModalEliminar(int id)
    {
        idToDelete = id;
        showDeleteModal = true;
    }

    private void EditarPresupuesto(int id) =>
        Navigation.NavigateTo($"/presupuesto-mensual/editar/{id}");

    private async Task ConfirmarEliminar()
    {
        await PresupuestoService.DeleteAsync(idToDelete);
        showDeleteModal = false;
        await Filtrar();
    }

    // ── Modal Ajustar Saldo ──────────────────────────────────────────────────

    private async Task AbrirModalSaldo(int id)
    {
        presupuestoIdSaldo  = id;
        dtoSaldo            = new CreateSaldoPresupuestoDto();
        montoSaldoTexto     = string.Empty;
        errorSaldo          = null;
        showConfirmSaldoModal = false;
        historialSaldos     = await SaldoService.GetByPresupuestoIdAsync(id);
        showSaldoModal      = true;
    }

    private void CerrarModalSaldo()
    {
        showSaldoModal = false;
        showConfirmSaldoModal = false;
        errorSaldo     = null;
    }

    private void OnMontoSaldoInput(ChangeEventArgs e)
    {
        var raw  = e.Value?.ToString() ?? string.Empty;
        var solo = new string(raw.Where(char.IsDigit).ToArray());

        if (string.IsNullOrEmpty(solo))
        {
            dtoSaldo.Monto  = 0;
            montoSaldoTexto = string.Empty;
            return;
        }

        if (long.TryParse(solo, out var valor))
        {
            dtoSaldo.Monto  = valor;
            montoSaldoTexto = valor.ToString("N0", new System.Globalization.CultureInfo("es-CL"));
        }
    }

    private void GuardarSaldo()
    {
        // En lugar de guardar directamente, mostramos el modal de confirmación
        if (dtoSaldo.Monto > 0)
        {
            showConfirmSaldoModal = true;
        }
    }

    private async Task ConfirmarGuardarSaldo()
    {
        showConfirmSaldoModal = false;
        savingSaldo = true;
        errorSaldo  = null;
        try
        {
            await SaldoService.CreateAsync(presupuestoIdSaldo, dtoSaldo);
            // Recargar historial y lista principal
            historialSaldos = await SaldoService.GetByPresupuestoIdAsync(presupuestoIdSaldo);
            dtoSaldo        = new CreateSaldoPresupuestoDto();
            montoSaldoTexto = string.Empty;
            await Filtrar();
        }
        catch (Exception ex)
        {
            errorSaldo = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            savingSaldo = false;
        }
    }

    private async Task EliminarSaldo(int id)
    {
        await SaldoService.DeleteAsync(id);
        historialSaldos = await SaldoService.GetByPresupuestoIdAsync(presupuestoIdSaldo);
        await Filtrar();
    }
}
