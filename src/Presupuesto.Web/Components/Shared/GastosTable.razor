@using Presupuesto.Application.DTOs
@using Presupuesto.Domain.Enums

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Fecha</th>
                <th>Categoría</th>
                <th>Descripción</th>
                <th class="text-end">Monto</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Gastos is null || !Gastos.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No hay gastos registrados
                    </td>
                </tr>
            }
            else
            {
                @foreach (var gasto in Gastos)
                {
                    <tr>
                        <td>@gasto.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="badge @GetCategoriaBadgeClass(gasto.Categoria)">
                                @gasto.CategoriaTexto
                            </span>
                        </td>
                        <td>@gasto.Descripcion</td>
                        <td class="text-end fw-bold">@gasto.Monto.ToString("C2")</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OnEdit.InvokeAsync(gasto.Id)" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => OnDelete.InvokeAsync(gasto.Id)" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
        @if (Gastos is not null && Gastos.Any())
        {
            <tfoot class="table-light">
                <tr>
                    <td colspan="3" class="text-end fw-bold">Total:</td>
                    <td class="text-end fw-bold text-success">@Gastos.Sum(g => g.Monto).ToString("C2")</td>
                    <td></td>
                </tr>
            </tfoot>
        }
    </table>
</div>

@code {
    [Parameter]
    public List<GastoDto>? Gastos { get; set; }

    [Parameter]
    public EventCallback<int> OnEdit { get; set; }

    [Parameter]
    public EventCallback<int> OnDelete { get; set; }

    private string GetCategoriaBadgeClass(Categoria categoria) => categoria switch
    {
        Categoria.Alimentacion => "bg-success",
        Categoria.Transporte => "bg-primary",
        Categoria.Servicios => "bg-info",
        Categoria.Entretenimiento => "bg-warning text-dark",
        Categoria.Otros => "bg-secondary",
        _ => "bg-secondary"
    };
}
