@using Presupuesto.Application.DTOs
@using Presupuesto.Domain.Enums

@if (Gastos is null || !Gastos.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        No hay gastos registrados
    </div>
}
else
{
    @* ===== Vista Desktop: Tabla clásica ===== *@
    <div class="gastos-desktop">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Fecha</th>
                        <th>Categoría</th>
                        <th>Descripción</th>
                        <th class="text-end">Monto</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gasto in Gastos)
                    {
                        <tr>
                            <td>@gasto.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge @GetCategoriaBadgeClass(gasto.CategoriaPresupuestoNombre)">
                                    @gasto.CategoriaTexto
                                </span>
                            </td>
                            <td>@gasto.Descripcion</td>
                            <td class="text-end fw-bold">@gasto.Monto.ToString("C2")</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OnEdit.InvokeAsync(gasto.Id)" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => OnDelete.InvokeAsync(gasto.Id)" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Total:</td>
                        <td class="text-end fw-bold text-success">@Gastos.Sum(g => g.Monto).ToString("C2")</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    @* ===== Vista Móvil: Tarjetas apiladas ===== *@
    <div class="gastos-mobile">
        @foreach (var gasto in Gastos)
        {
            <div class="gasto-card">
                <div class="gasto-card-top">
                    <span class="badge @GetCategoriaBadgeClass(gasto.CategoriaPresupuestoNombre)">
                        @gasto.CategoriaTexto
                    </span>
                    <span class="gasto-card-fecha">
                        <i class="bi bi-calendar3 me-1"></i>@gasto.Fecha.ToString("dd/MM/yyyy")
                    </span>
                </div>
                <div class="gasto-card-desc">@gasto.Descripcion</div>
                <div class="gasto-card-bottom">
                    <span class="gasto-card-monto">@gasto.Monto.ToString("C2")</span>
                    <div class="gasto-card-actions">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => OnEdit.InvokeAsync(gasto.Id)" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => OnDelete.InvokeAsync(gasto.Id)" title="Eliminar">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
        <!-- Total móvil -->
        <div class="gasto-card gasto-card-total">
            <div class="gasto-card-bottom">
                <span class="fw-bold text-muted">
                    <i class="bi bi-calculator me-1"></i>Total (@Gastos.Count @(Gastos.Count == 1 ? "gasto" : "gastos"))
                </span>
                <span class="gasto-card-monto text-success">@Gastos.Sum(g => g.Monto).ToString("C2")</span>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public List<GastoDto>? Gastos { get; set; }

    [Parameter]
    public EventCallback<int> OnEdit { get; set; }

    [Parameter]
    public EventCallback<int> OnDelete { get; set; }

    private int GetColorIndex(string seedName)
    {
        if (string.IsNullOrEmpty(seedName)) return 0;
        int hash = 0;
        for (int i = 0; i < seedName.Length; i++)
        {
            hash = seedName[i] + ((hash << 5) - hash);
        }
        return Math.Abs(hash);
    }

    private string GetCategoriaBadgeClass(string? nombre)
    {
        if (string.IsNullOrEmpty(nombre)) return "bg-secondary";
        if (nombre == "Obligaciones") return "bg-success";
        
        string[] badges = { "bg-primary", "bg-info text-dark", "bg-warning text-dark", "bg-danger", "bg-secondary", "bg-dark" };
        var index = GetColorIndex(nombre) % badges.Length;
        return badges[index];
    }
}

<style>
    /* ===== Visibility toggle ===== */
    .gastos-mobile {
        display: none;
    }
    .gastos-desktop {
        display: block;
    }

    @@media (max-width: 767.98px) {
        .gastos-desktop {
            display: none;
        }
        .gastos-mobile {
            display: block;
            padding: 12px;
        }
    }

    /* ===== Mobile card styles ===== */
    .gasto-card {
        background: #fff;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 10px;
        border: 1px solid #e9ecef;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
        transition: box-shadow 0.2s ease;
    }

    .gasto-card:hover {
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
    }

    .gasto-card:last-child {
        margin-bottom: 0;
    }

    .gasto-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .gasto-card-fecha {
        font-size: 0.78rem;
        color: #6c757d;
        font-weight: 500;
    }

    .gasto-card-desc {
        font-size: 0.92rem;
        color: #495057;
        margin-bottom: 10px;
        line-height: 1.4;
    }

    .gasto-card-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .gasto-card-monto {
        font-size: 1.15rem;
        font-weight: 700;
        color: #212529;
    }

    .gasto-card-actions {
        display: flex;
        gap: 6px;
    }

    .gasto-card-actions .btn {
        padding: 4px 10px;
    }

    /* ===== Total row ===== */
    .gasto-card-total {
        background: #e8f5e9;
        border-color: #c8e6c9;
    }
</style>
